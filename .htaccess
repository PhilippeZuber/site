# ---------------------------------
# Basis-Schutz
# ---------------------------------

# Kein Directory Listing
Options -Indexes

# Sensible Dateien sperren
<FilesMatch "\.(htaccess|git|env|sql|ini|log|sh|bak)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Schutz fuer .htaccess selbst
<Files ".htaccess">
    Order allow,deny
    Deny from all
</Files>

